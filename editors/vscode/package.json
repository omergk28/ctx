{
  "name": "ctx-context",
  "displayName": "ctx — Persistent Context for AI",
  "description": "Chat participant (@ctx) for persistent project context across AI coding sessions",
  "version": "0.8.1",
  "publisher": "activememory",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ActiveMemory/ctx",
  "bugs": {
    "url": "https://github.com/ActiveMemory/ctx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ActiveMemory/ctx"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "markdown": "github",
  "qna": "https://github.com/ActiveMemory/ctx/discussions",
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ctx",
    "context",
    "ai",
    "copilot",
    "chat"
  ],
  "pricing": "Free",
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "ctx.participant",
        "name": "ctx",
        "fullName": "ctx",
        "description": "Persistent project context for AI coding sessions",
        "isSticky": true,
        "commands": [
          {
            "name": "init",
            "description": "Initialize a new .context/ directory with template files"
          },
          {
            "name": "status",
            "description": "Show context summary with token estimate"
          },
          {
            "name": "agent",
            "description": "Print AI-ready context packet"
          },
          {
            "name": "drift",
            "description": "Detect stale or invalid context"
          },
          {
            "name": "recall",
            "description": "Browse and search AI session history"
          },
          {
            "name": "hook",
            "description": "Generate AI tool integration configs (e.g. copilot, claude)"
          },
          {
            "name": "add",
            "description": "Add a new item to a context file (task, decision, learning)"
          },
          {
            "name": "load",
            "description": "Output assembled context Markdown"
          },
          {
            "name": "compact",
            "description": "Archive completed tasks and clean up context"
          },
          {
            "name": "sync",
            "description": "Reconcile context with codebase"
          },
          {
            "name": "task",
            "description": "Task operations: complete, archive, snapshot"
          },
          {
            "name": "remind",
            "description": "Manage session-scoped reminders"
          },
          {
            "name": "pad",
            "description": "Encrypted scratchpad for sensitive notes"
          },
          {
            "name": "notify",
            "description": "Send webhook notifications"
          },
          {
            "name": "system",
            "description": "System diagnostics and bootstrap"
          },
          {
            "name": "memory",
            "description": "Memory bridge operations (sync, status, diff, import, publish)"
          },
          {
            "name": "journal",
            "description": "Journal management (site, obsidian)"
          },
          {
            "name": "doctor",
            "description": "Context health diagnostics"
          },
          {
            "name": "config",
            "description": "Runtime configuration (switch, status, schema)"
          },
          {
            "name": "prompt",
            "description": "Prompt templates (list, add, show, rm)"
          },
          {
            "name": "why",
            "description": "Show rationale for context design decisions"
          },
          {
            "name": "change",
            "description": "Show recent codebase changes"
          },
          {
            "name": "dep",
            "description": "Show project dependencies"
          },
          {
            "name": "guide",
            "description": "Quick start guide"
          },
          {
            "name": "permission",
            "description": "Permission snapshot and restore"
          },
          {
            "name": "site",
            "description": "Documentation site (feed)"
          },
          {
            "name": "loop",
            "description": "Generate autonomous iteration scripts"
          },
          {
            "name": "pause",
            "description": "Pause context hooks for current session"
          },
          {
            "name": "resume",
            "description": "Resume context hooks"
          },
          {
            "name": "reindex",
            "description": "Rebuild context file indices"
          },
          {
            "name": "diag",
            "description": "Diagnose extension issues — times each step to find hangs"
          }
        ],
        "disambiguation": [
          {
            "category": "context",
            "description": "The user wants to manage persistent project context, initialize a .context/ directory, check context status, detect drift, recall session history, or load context for AI sessions.",
            "examples": [
              "Initialize project context",
              "Show my context status",
              "What is the context drift?",
              "Load my project context",
              "Recall previous AI sessions",
              "Add a task to my context",
              "Compact my context files"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "ctx",
      "properties": {
        "ctx.executablePath": {
          "type": "string",
          "default": "ctx",
          "description": "Path to the ctx executable. Defaults to 'ctx' (found via PATH)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "overrides": {
    "lodash": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.0.18"
  }
}
